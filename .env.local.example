# Local AWS API emulation (LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
LOCALSTACK_ENDPOINT=http://localstack:4566
LOCALSTACK_ENDPOINT_HOST=http://localhost:4566
LOCALSTACK_HOST=localhost
LOCALSTACK_PORT=4566
SECRET_ID=lakehouse/dev/credentials

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT_INTERNAL=http://minio:9000
MINIO_ENDPOINT_HOST=http://localhost:9000
S3_BUCKET=lakehouse-raw-local

# Snowflake connection (source values for LocalStack Secrets Manager bootstrap)
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=DBT_USER
SNOWFLAKE_PASSWORD=replace-with-password
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=LAKEHOUSE
SNOWFLAKE_SCHEMA=RAW

# dbt runtime (stored in LocalStack secret)
DBT_TARGET=dev
